        S3["Check __proto__ / prototype pollution"]
        S4["Check process.env / fs access"]
        S5["Check network requests (fetch/http)"]
        S6["Check dynamic imports"]
        SS["Safety Score = 100 - Σ penalties"]
    end

    subgraph SecurityAnalysis["Security Analysis (30% Weight)"]
        K1["Check API keys (sk-, AKIA)"]
        K2["Check hardcoded tokens"]
        K3["Check passwords in code"]
        K4["Check connection strings"]
        K5["Check private keys"]
        KS["Security Score = 100 - Σ penalties"]
    end

    subgraph QualityAnalysis["Quality Analysis (30% Weight)"]
        Q1["Check empty catch blocks"]
        Q2["Check console.log statements"]
        Q3["Check TODO/FIXME markers"]
        Q4["Check missing type annotations"]
        Q5["Check error handling presence"]
        Q6["Check comment density"]
        QS["Quality Score = 100 - Σ penalties + bonuses"]
    end

    Input --> SafetyAnalysis
    Input --> SecurityAnalysis
    Input --> QualityAnalysis

    S1 --> SS
    S2 --> SS
    S3 --> SS
    S4 --> SS
    S5 --> SS
    S6 --> SS

    K1 --> KS
    K2 --> KS
    K3 --> KS
    K4 --> KS
    K5 --> KS

    Q1 --> QS
    Q2 --> QS
    Q3 --> QS
    Q4 --> QS
    Q5 --> QS
    Q6 --> QS

    SS --> Overall
    KS --> Overall
    QS --> Overall

    Overall["Overall Score<br/>= Safety×0.4 + Security×0.3 + Quality×0.3"]
    Overall --> Classification

    Classification{"Score >= 80?"}
    Classification -->|Yes| Pass["✅ PASSED"]
    Classification -->|No| Review["⚠️ REVIEW"]

